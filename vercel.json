{
  "functions": {
    "publica/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "administrador/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/administrador/index.php"
    },
    {
      "source": "/admin.php",
      "destination": "/administrador/index.php"
    },
    {
      "source": "/administrador",
      "destination": "/administrador/index.php"
    },
    {
      "source": "/legal",
      "destination": "/publica/legal.php"
    },
    {
      "source": "/legal.php",
      "destination": "/publica/legal.php"
    },
    {
      "source": "/",
      "destination": "/publica/index.php"
    }
  ]
}
