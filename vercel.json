{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/admin.php"
    },
    {
      "source": "/admin.php",
      "destination": "/api/admin.php"
    },
    {
      "source": "/administrador",
      "destination": "/api/admin.php"
    },
    {
      "source": "/administrador/index.php",
      "destination": "/api/admin.php"
    },
    {
      "source": "/legal",
      "destination": "/api/legal.php"
    },
    {
      "source": "/legal.php",
      "destination": "/api/legal.php"
    },
    {
      "source": "/",
      "destination": "/api/index.php"
    }
  ]
}
